#!/usr/bin/env fish
{{ if eq .chezmoi.os "linux" -}}

# packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

# force sudo to stay on the terminal
set -x SUDO_ASKPASS ""
# tell Flatpak to skip any GUI
set -x FLATPAK_CLI 1
# keep GTK quiet
set -x NO_AT_BRIDGE 1

{{ include ".chezmoihelpers/status.fish" }}
{{ include ".chezmoitemplates/fish_logging.fish" }}
{{ include ".chezmoitemplates/package_reporting.fish" }}
setup_logging linux-install-packages

# Install RPM packages with dnf
function install_dnf_packages
    set packages $argv
    if test (count $argv) -gt 0
        set versions_before (mktemp)
        set versions_after (mktemp)
        snapshot_rpm_versions $versions_before $packages
        step_run_quiet "RPM packages" sudo dnf install -y $argv
        set run_status $status
        if test $run_status -eq 0
            snapshot_rpm_versions $versions_after $packages
            count_package_changes $versions_before $versions_after
            if test $package_change_count -eq 0
                set result_note "no changes"
            else
                set result_note installed
            end
            step_result_note "RPM packages" "$result_note"
            report_package_updates $versions_before $versions_after
        end
        rm -f $versions_before $versions_after
        return $run_status
    else
        step_skip_ok "No RPM packages configured"
    end
end

# Install Flatpak packages
function install_flatpak_packages
    set remote $argv[1]
    set packages $argv[2..]

    if test (count $packages) -gt 0
        set versions_before (mktemp)
        set versions_after (mktemp)
        snapshot_flatpak_versions $versions_before $packages
        step_run_quiet "Flatpak packages [$remote]" sudo env XDG_DATA_DIRS="/var/lib/flatpak/exports/share:/root/.local/share/flatpak/exports/share:/usr/local/share:/usr/share" dbus-run-session flatpak install --system $remote --noninteractive --assumeyes --or-update $packages
        set run_status $status
        if test $run_status -eq 0
            snapshot_flatpak_versions $versions_after $packages
            count_package_changes $versions_before $versions_after
            if test $package_change_count -eq 0
                set result_note "no changes"
            else
                set result_note installed
            end
            step_result_note "Flatpak packages [$remote]" "$result_note"
            report_package_updates $versions_before $versions_after
        end
        rm -f $versions_before $versions_after
        return $run_status
    else
        step_skip_ok "No Flatpak packages configured for $remote"
    end
end

# Initialize package arrays
set rpm_packages
set fedora_flatpak_packages
set flathub_flatpak_packages

# Add common packages
{{ range .packages.common.rpm -}}
set -a rpm_packages '{{ . }}'
{{ end }}

{{ range .packages.common.flatpak.fedora -}}
set -a fedora_flatpak_packages '{{ . }}'
{{ end }}

{{ range .packages.common.flatpak.flathub -}}
set -a flathub_flatpak_packages '{{ . }}'
{{ end }}

# Add role-specific packages
{{ if .isClient -}}
{{ range .packages.client.rpm -}}
set -a rpm_packages '{{ . }}'
{{ end }}

{{ range .packages.client.flatpak.fedora -}}
set -a fedora_flatpak_packages '{{ . }}'
{{ end }}

{{ range .packages.client.flatpak.flathub -}}
set -a flathub_flatpak_packages '{{ . }}'
{{ end }}
{{ else if .isServer -}}
{{ range .packages.server.rpm -}}
set -a rpm_packages '{{ . }}'
{{ end }}

{{ range .packages.server.flatpak.fedora -}}
set -a fedora_flatpak_packages '{{ . }}'
{{ end }}

{{ range .packages.server.flatpak.flathub -}}
set -a flathub_flatpak_packages '{{ . }}'
{{ end }}
{{ end }}

# Install all packages
install_dnf_packages $rpm_packages
or exit 1

# Install Flatpak packages directly from their respective remotes
install_flatpak_packages fedora $fedora_flatpak_packages
or exit 1

install_flatpak_packages flathub $flathub_flatpak_packages
or exit 1

# Remove unused Flatpak packages
set flatpak_refs_before (mktemp)
set flatpak_refs_after (mktemp)
snapshot_flatpak_refs $flatpak_refs_before

set previous_stage $chezetc_stage
set chezetc_stage REMOVE
step_run_quiet "Flatpak packages [unused]" sudo env XDG_DATA_DIRS="/var/lib/flatpak/exports/share:/root/.local/share/flatpak/exports/share:/usr/local/share:/usr/share" dbus-run-session flatpak remove --system --unused -y
set remove_status $status
if test $remove_status -eq 0
    snapshot_flatpak_refs $flatpak_refs_after
    count_removed_entries $flatpak_refs_before $flatpak_refs_after
    if test $package_change_count -eq 0
        set result_note "no changes"
    else
        set result_note removed
    end
    step_result_note "Flatpak packages [unused]" "$result_note"
end
set chezetc_stage $previous_stage
rm -f $flatpak_refs_before $flatpak_refs_after
test $remove_status -eq 0
or exit 1
{{ end }}
