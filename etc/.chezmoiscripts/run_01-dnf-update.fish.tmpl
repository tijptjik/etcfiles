#!/usr/bin/env fish

{{ include ".chezmoihelpers/status.fish" }}

if command -q gum; and isatty stdout
    gum style --foreground 14 --bold "System Update"
else
    echo "System Update"
end
echo

if not command -q gum
    __stage_label INSTALL "..." "Install gum CLI runner"
    if sudo dnf install -y -q gum
        __stage_result INSTALL "Install gum CLI runner"
    else
        __stage_failure "Install gum CLI runner"
        exit 1
    end
end

{{ include ".chezmoitemplates/fish_logging.fish" }}
setup_logging linux-dnf-update

step_run "System packages" sudo dnf update -y
or exit 1
