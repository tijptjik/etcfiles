#!/usr/bin/env fish

{{ include ".chezmoihelpers/status.fish" }}
{{ include ".chezmoitemplates/fish_logging.fish" }}
setup_logging linux-enable-docker

step_header "Docker"

# Add user to docker group
if [ "$USER" != "root" ]
    step_run "Add $USER to docker group" sudo usermod -aG docker $USER
    or exit 1
else
    step_skip "Docker group membership for root"
end

# Check if docker is already enabled
if systemctl is-enabled docker >/dev/null 2>&1
    step_skip "Docker service enabled"
else
    step_run "Enable Docker service" sudo systemctl enable docker
    or exit 1
end

# Check if docker is already active
if systemctl is-active docker >/dev/null 2>&1
    step_skip "Docker service active"
else
    step_run "Start Docker service" sudo systemctl start docker
    or exit 1
end
