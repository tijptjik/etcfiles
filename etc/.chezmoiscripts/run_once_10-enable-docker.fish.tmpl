#!/usr/bin/env fish

{{ include ".chezmoihelpers/status.fish" }}
{{ include ".chezmoitemplates/fish_logging.fish" }}
setup_logging linux-enable-docker

step_header "Docker"

# Add user to docker group
if [ "$USER" != "root" ]
    step_run_note "Group membership for $USER" configured sudo usermod -aG docker $USER
    or exit 1
else
    step_skip_ok "Group membership for root" "not needed"
end

# Check if docker is already enabled
if systemctl is-enabled docker >/dev/null 2>&1
    step_skip_ok Service enabled
else
    step_run_note Service enabled sudo systemctl enable docker
    or exit 1
end

# Check if docker is already active
if systemctl is-active docker >/dev/null 2>&1
    step_skip_ok Service active
else
    step_run_note Service active sudo systemctl start docker
    or exit 1
end
