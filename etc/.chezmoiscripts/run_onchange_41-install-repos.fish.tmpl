#!/usr/bin/env fish
{{ if eq .chezmoi.os "linux" -}}

set -x SUDO_ASKPASS ""           # force sudo to ask on the terminal

# repos.yaml hash: {{ include ".chezmoidata/repos.yaml" | sha256sum }}

{{ include ".chezmoitemplates/fish_logging.fish" }}
setup_logging linux-install-repos

# --- RPM Fusion Handling ---
function handle_rpmfusion
    if ! rpm -q rpmfusion-free-release >/dev/null 2>&1
        step_run "Install RPM Fusion Free repository" sudo dnf install -y "https://download1.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm"
        or return 1
    else
        step_skip "RPM Fusion Free repository already installed"
    end

    if ! rpm -q rpmfusion-nonfree-release >/dev/null 2>&1
        step_run "Install RPM Fusion Non-Free repository" sudo dnf install -y "https://download1.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm"
        or return 1
    else
        step_skip "RPM Fusion Non-Free repository already installed"
    end
end

# --- Generic Repo Handling ---
function add_repo
    set repo_name $argv[1]
    set repo_url $argv[2]
    set gpg_key $argv[3]

    # Import GPG key if provided
    if test -n "$gpg_key"
        # Use curl to download the key and pipe to rpm --import
        step_run "Import GPG key for $repo_name" fish -c "curl -sSL '$gpg_key' | sudo rpm --import -"
        or return 1
    end

    # Add the repository
    step_run "Add repository $repo_name" sudo dnf config-manager addrepo --from-repofile="$repo_url" --overwrite
    or return 1
end

# --- Prerequisite Check ---
function ensure_dnf_plugins_core
    if ! rpm -q dnf-plugins-core >/dev/null 2>&1
        step_run "Install dnf-plugins-core" sudo dnf install -y dnf-plugins-core
        or exit 1
    else
        step_skip "dnf-plugins-core already installed"
    end
end


# --- Main Logic ---

# Ensure dnf-plugins-core is installed
ensure_dnf_plugins_core

# Handle RPM Fusion separately as it's a package install
handle_rpmfusion
or exit 1

# Process common repositories
step_header "Common DNF repositories"
{{ range $name, $repo := .repos.common  }}
{{ if and (ne $name "flathub") (ne $repo.url "dynamic") -}}
{{ $gpg_key := "" -}}
{{ if hasKey $repo "gpg_key" -}}
{{ $gpg_key = $repo.gpg_key -}}
{{ end -}}
add_repo '{{ $repo.name }}' '{{ $repo.url }}' '{{ $gpg_key }}'
or exit 1
{{ end -}}
{{ end }}

# TODO Clean up
# Install DNF installed repo for server
{{ if .isServer }}
step_run "Install GetPageSpeed repository" sudo dnf install -y https://extras.getpagespeed.com/release-latest.rpm
or exit 1
{{ end }}


# Process client-specific repositories if applicable
{{ if .isClient }}
step_header "Client DNF repositories"
{{ range $name, $repo := .repos.client }}
{{ if and (ne $name "flathub") (ne $repo.url "dynamic") -}}
{{ $gpg_key := "" -}}
{{ if hasKey $repo "gpg_key" -}}
{{ $gpg_key = $repo.gpg_key -}}
{{ end -}}
add_repo '{{ $repo.name }}' '{{ $repo.url }}' '{{ $gpg_key }}'
or exit 1
{{ end -}}
{{ end }}
{{ end }}

step_ok "DNF repositories processed"

{{ end -}}
